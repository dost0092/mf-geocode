# PostgreSQL SQLAlchemy URL
DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/dbname

# Nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=hotel-geocoder/1.0 (contact: you@example.com)
# Public Nominatim: keep 1 rps. If self-hosted/paid, increase.
NOMINATIM_RPS=1.0

# Masterfile table info
MASTERFILE_SCHEMA=ingestion
MASTERFILE_TABLE=hotel_masterfile
MASTERFILE_PK=hotel_id

# Column names in hotel_masterfile (edit to match your schema)
COL_COUNTRY_CODE=country_code
COL_LAT=latitude
COL_LNG=longitude
COL_STATE_CODE=state_code

# Address fields for forward geocode (edit to match your schema)
COL_ADDRESS1=address
COL_CITY=city
COL_STATE_TEXT=state
COL_POSTAL=postal_code

# US states reference
US_STATES_SCHEMA=test
US_STATES_TABLE=us_states
US_STATES_NAME_COL=state_name
US_STATES_CODE_COL=state_code

# Batch behavior
DEFAULT_LIMIT=200
DEFAULT_MAX_SECONDS=25
MAX_MOVE_KM=50

# Safety
DRY_RUN=false
